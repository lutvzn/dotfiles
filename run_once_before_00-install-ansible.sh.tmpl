{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

LOG_HOME="${ORIG_HOME:-$HOME}"
LOG_DIR="$LOG_HOME/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_once_before_00-install-ansible.log"

mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

ensure_root() {
  if [ "$(id -u)" -eq 0 ]; then
    return
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    log_message "ERROR: sudo is required to install Ansible."
    exit 1
  fi

  log_message "INFO: Escalating with sudo to install Ansible."
  exec sudo ORIG_HOME="$HOME" bash "$0" "$@"
}

detect_os() {
  if [ ! -r /etc/os-release ]; then
    log_message "ERROR: /etc/os-release is not available. Cannot detect the operating system."
    exit 1
  fi

  . /etc/os-release
  DISTRO_ID="${ID:-}"
  DISTRO_LIKE="${ID_LIKE:-}"
}

install_with_apt() {
  log_message "INFO: Installing Ansible with apt."

  if ! apt-get update; then
    log_message "ERROR: apt-get update failed."
    exit 1
  fi

  if apt-get install -y ansible; then
    log_message "SUCCESS: Ansible installed with apt."
  else
    log_message "ERROR: Failed to install Ansible with apt."
    exit 1
  fi
}

install_with_dnf() {
  log_message "INFO: Installing Ansible with dnf."

  if dnf install -y ansible; then
    log_message "SUCCESS: Ansible installed with dnf."
  else
    log_message "ERROR: Failed to install Ansible with dnf."
    exit 1
  fi
}

install_with_zypper() {
  log_message "INFO: Installing Ansible with zypper."

  if zypper --non-interactive refresh && zypper --non-interactive install --no-confirm ansible; then
    log_message "SUCCESS: Ansible installed with zypper."
  else
    log_message "ERROR: Failed to install Ansible with zypper."
    exit 1
  fi
}

install_with_pacman() {
  log_message "INFO: Installing Ansible with pacman."

  if pacman -Sy --noconfirm ansible; then
    log_message "SUCCESS: Ansible installed with pacman."
  else
    log_message "ERROR: Failed to install Ansible with pacman."
    exit 1
  fi
}

install_with_xbps() {
  log_message "INFO: Installing Ansible with xbps-install."

  if xbps-install -Sy ansible; then
    log_message "SUCCESS: Ansible installed with xbps-install."
  else
    log_message "ERROR: Failed to install Ansible with xbps-install."
    exit 1
  fi
}

install_with_apk() {
  log_message "INFO: Installing Ansible with apk."

  if apk add ansible; then
    log_message "SUCCESS: Ansible installed with apk."
  else
    log_message "ERROR: Failed to install Ansible with apk."
    exit 1
  fi
}

ensure_root "$@"
detect_os

if command -v ansible >/dev/null 2>&1; then
  log_message "INFO: Ansible is already installed at $(command -v ansible)."
  exit 0
fi

case "$DISTRO_ID" in
  ubuntu)
    install_with_apt
    ;;
  fedora)
    install_with_dnf
    ;;
  arch|artix)
    install_with_pacman
    ;;
  void)
    install_with_xbps
    ;;
  alpine)
    install_with_apk
    ;;
  opensuse*|sles)
    install_with_zypper
    ;;
  *)
    case " $DISTRO_LIKE " in
      *" debian "*)
        install_with_apt
        ;;
      *" arch "*)
        install_with_pacman
        ;;
      *" fedora "*|*" rhel "*)
        install_with_dnf
        ;;
      *" suse "*)
        install_with_zypper
        ;;
      *)
        log_message "ERROR: Unsupported distribution ID '$DISTRO_ID' (ID_LIKE='$DISTRO_LIKE')."
        exit 1
        ;;
    esac
    ;;
esac

if command -v ansible >/dev/null 2>&1; then
  log_message "SUCCESS: Ansible is available at $(command -v ansible)."
else
  log_message "ERROR: Installation completed but ansible is still not available in PATH."
  exit 1
fi
{{ end -}}
