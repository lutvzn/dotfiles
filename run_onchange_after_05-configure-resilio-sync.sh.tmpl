{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

# resilio-sync.service hash: {{ include "dot_config/systemd/user/resilio-sync.service.tmpl" | sha256sum }}
# resilio-sync.conf hash: {{ include "dot_config/resilio-sync/rslsync.conf.tmpl" | sha256sum }}

LOG_DIR="$HOME/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_onchange_after_05-configure-resilio-sync.log"
RSLSYNC_BIN=""
SYNC_ROOT="/var/sync"

# Ensure the log directory exists
mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

resolve_rslsync_bin() {
  local candidate

  for candidate in \
    "$(command -v rslsync 2>/dev/null)" \
    "/home/linuxbrew/.linuxbrew/bin/rslsync" \
    "/opt/homebrew/bin/rslsync" \
    "/usr/local/bin/rslsync"; do
    if [ -x "$candidate" ]; then
      RSLSYNC_BIN="$candidate"
      return 0
    fi
  done

  return 1
}

run_with_sudo() {
  if ! command -v sudo >/dev/null 2>&1; then
    log_message "ERROR: sudo is required to manage $SYNC_ROOT ownership."
    exit 1
  fi

  sudo "$@"
}

log_message "Configuring resilio-sync user service..."

if [ ! -d "$SYNC_ROOT" ]; then
  log_message "Creating $SYNC_ROOT directory..."
  log_message "INFO: Escalating with sudo to create $SYNC_ROOT."
  if run_with_sudo mkdir -p "$SYNC_ROOT"; then
    log_message "SUCCESS: $SYNC_ROOT directory created."
  else
    log_message "ERROR: Failed to create $SYNC_ROOT directory."
    exit 1
  fi
fi

log_message "INFO: Escalating with sudo to set ownership on $SYNC_ROOT."
if run_with_sudo chown -R lutvzn:lutvzn "$SYNC_ROOT"; then
  log_message "SUCCESS: Ownership set on $SYNC_ROOT for lutvzn."
else
  log_message "ERROR: Failed to set ownership on $SYNC_ROOT."
  exit 1
fi

# Ensure the sync and config directories exist
mkdir -p "$HOME/Sync" "$HOME/.config/resilio-sync"

if ! command -v systemctl >/dev/null 2>&1; then
  log_message "WARNING: systemctl is not available; skipping resilio-sync service setup."
  exit 0
fi

if ! resolve_rslsync_bin; then
  log_message "WARNING: rslsync was not found in PATH or common Homebrew locations; install it before enabling the service."
  exit 0
fi

# Reload systemd user daemon
systemctl --user daemon-reload

# Enable and start the service
if systemctl --user enable --now resilio-sync.service; then
  log_message "SUCCESS: resilio-sync user service enabled and started."
else
  log_message "WARNING: Could not enable resilio-sync user service."
fi
{{ end -}}
