{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

LOG_HOME="${ORIG_HOME:-$HOME}"
LOG_DIR="$LOG_HOME/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_once_before_00-install-prereqs.log"
REQUIRED_PACKAGES=(git curl zsh)
MISSING_PACKAGES=()
TARGET_USER="${SUDO_USER:-${ORIG_USER:-$(id -un)}}"
TARGET_HOME="${ORIG_HOME:-$(getent passwd "$TARGET_USER" | cut -d: -f6)}"
BREW_PREFIX="/home/linuxbrew/.linuxbrew"
SUDOERS_FILE="/etc/sudoers.d/99-homebrew-secure-path"
BREW_SECURE_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/snap/bin:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin"

mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

run_with_sudo() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return
  fi
  if ! command -v sudo >/dev/null 2>&1; then
    log_message "ERROR: sudo is required to install prerequisites."
    exit 1
  fi

  sudo "$@"
}

run_as_target_user() {
  if [ "$(id -u)" -eq 0 ] && [ "$TARGET_USER" != "root" ]; then
    if ! command -v sudo >/dev/null 2>&1; then
      log_message "ERROR: sudo is required to run commands as $TARGET_USER."
      exit 1
    fi

    sudo -H -u "$TARGET_USER" "$@"
    return
  fi

  "$@"
}

detect_os() {
  if [ ! -r /etc/os-release ]; then
    log_message "ERROR: /etc/os-release is not available. Cannot detect the operating system."
    exit 1
  fi

  . /etc/os-release
  DISTRO_ID="${ID:-}"
  DISTRO_LIKE="${ID_LIKE:-}"
}

is_ostree() {
  [ -d /sys/fs/ostree ] || [ -f /run/ostree-booted ]
}

install_with_apt() {
  log_message "INFO: Installing missing prerequisite packages with apt: ${MISSING_PACKAGES[*]}."

  if ! run_with_sudo apt-get update; then
    log_message "ERROR: apt-get update failed."
    exit 1
  fi

  if run_with_sudo apt-get install -y "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages installed with apt."
  else
    log_message "ERROR: Failed to install missing prerequisite packages with apt."
    exit 1
  fi
}

install_with_dnf() {
  log_message "INFO: Installing missing prerequisite packages with dnf: ${MISSING_PACKAGES[*]}."

  if run_with_sudo dnf install -y "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages installed with dnf."
  else
    log_message "ERROR: Failed to install missing prerequisite packages with dnf."
    exit 1
  fi
}

install_with_rpm_ostree() {
  log_message "INFO: Installing missing prerequisite packages with rpm-ostree: ${MISSING_PACKAGES[*]}."

  if run_with_sudo rpm-ostree install "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages queued with rpm-ostree."
    log_message "INFO: A reboot may be required before the newly installed commands are available."
    log_message "INFO: Reboot the system and re-run chezmoi apply to continue bootstrap."
    exit 0
  else
    log_message "ERROR: Failed to install missing prerequisite packages with rpm-ostree."
    exit 1
  fi
}

install_with_zypper() {
  log_message "INFO: Installing missing prerequisite packages with zypper: ${MISSING_PACKAGES[*]}."

  if run_with_sudo zypper --non-interactive refresh && run_with_sudo zypper --non-interactive install --no-confirm "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages installed with zypper."
  else
    log_message "ERROR: Failed to install missing prerequisite packages with zypper."
    exit 1
  fi
}

find_transactional_update() {
  local candidate

  for candidate in transactional-update /usr/sbin/transactional-update /sbin/transactional-update; do
    if command -v "$candidate" >/dev/null 2>&1; then
      command -v "$candidate"
      return 0
    fi
  done

  return 1
}

install_with_transactional_update() {
  local transactional_update_bin

  if ! transactional_update_bin="$(find_transactional_update)"; then
    log_message "ERROR: transactional-update is required on openSUSE MicroOS but was not found."
    exit 1
  fi

  log_message "INFO: Installing missing prerequisite packages with transactional-update: ${MISSING_PACKAGES[*]}."

  if run_with_sudo "$transactional_update_bin" --non-interactive pkg install "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages queued with transactional-update."
    log_message "INFO: A reboot is required before the newly installed commands are available."
    log_message "INFO: Reboot the system and re-run chezmoi apply to continue bootstrap."
    exit 0
  else
    log_message "ERROR: Failed to install missing prerequisite packages with transactional-update."
    exit 1
  fi
}

install_with_pacman() {
  log_message "INFO: Installing missing prerequisite packages with pacman: ${MISSING_PACKAGES[*]}."

  if run_with_sudo pacman -Sy --noconfirm "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages installed with pacman."
  else
    log_message "ERROR: Failed to install missing prerequisite packages with pacman."
    exit 1
  fi
}

install_with_xbps() {
  log_message "INFO: Installing missing prerequisite packages with xbps-install: ${MISSING_PACKAGES[*]}."

  if run_with_sudo xbps-install -Sy "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages installed with xbps-install."
  else
    log_message "ERROR: Failed to install missing prerequisite packages with xbps-install."
    exit 1
  fi
}

install_with_apk() {
  log_message "INFO: Installing missing prerequisite packages with apk: ${MISSING_PACKAGES[*]}."

  if run_with_sudo apk add "${MISSING_PACKAGES[@]}"; then
    log_message "SUCCESS: Missing prerequisite packages installed with apk."
  else
    log_message "ERROR: Failed to install missing prerequisite packages with apk."
    exit 1
  fi
}

find_missing_required_packages() {
  local package

  MISSING_PACKAGES=()

  for package in "${REQUIRED_PACKAGES[@]}"; do
    if ! command -v "$package" >/dev/null 2>&1; then
      log_message "INFO: Missing required command: $package."
      MISSING_PACKAGES+=("$package")
    fi
  done
}

have_required_packages() {
  find_missing_required_packages
  [ "${#MISSING_PACKAGES[@]}" -eq 0 ]
}

source_brew_environment() {
  local brew_bin

  for brew_bin in \
    "/home/linuxbrew/.linuxbrew/bin/brew" \
    "/opt/homebrew/bin/brew" \
    "/usr/local/bin/brew"; do
    if [ -x "$brew_bin" ]; then
      eval "$("$brew_bin" shellenv)"
      return 0
    fi
  done

  return 1
}

have_brew() {
  command -v brew >/dev/null 2>&1
}

prepare_brew_prefix() {
  if [ -d "$BREW_PREFIX" ]; then
    return
  fi

  log_message "INFO: Creating Homebrew prefix at $BREW_PREFIX for user $TARGET_USER."

  if run_with_sudo mkdir -p "$BREW_PREFIX" \
    && run_with_sudo chown -R "$TARGET_USER":"$TARGET_USER" "$BREW_PREFIX"; then
    log_message "SUCCESS: Homebrew prefix prepared successfully."
  else
    log_message "ERROR: Failed to prepare Homebrew prefix at $BREW_PREFIX."
    exit 1
  fi
}

configure_sudo_homebrew_path() {
  local temp_sudoers
  local visudo_bin=""
  local candidate

  for candidate in /usr/sbin/visudo /sbin/visudo /usr/bin/visudo visudo; do
    if command -v "$candidate" >/dev/null 2>&1; then
      visudo_bin="$(command -v "$candidate")"
      break
    fi
  done

  if [ -z "$visudo_bin" ]; then
    log_message "ERROR: visudo is required to safely configure sudo secure_path."
    exit 1
  fi

  temp_sudoers="$(mktemp "${TMPDIR:-/tmp}/homebrew-secure-path.XXXXXX")"

  {
    echo "# Managed by chezmoi. Allows sudo to resolve commands installed by Linuxbrew."
    echo "Defaults secure_path=\"$BREW_SECURE_PATH\""
  } >"$temp_sudoers"

  if ! "$visudo_bin" -cf "$temp_sudoers" >/dev/null; then
    log_message "ERROR: Generated sudoers configuration failed validation."
    rm -f "$temp_sudoers"
    exit 1
  fi

  if run_with_sudo install -o root -g root -m 0440 "$temp_sudoers" "$SUDOERS_FILE"; then
    rm -f "$temp_sudoers"
    log_message "SUCCESS: sudo secure_path includes Homebrew commands."
  else
    log_message "ERROR: Failed to install $SUDOERS_FILE."
    rm -f "$temp_sudoers"
    exit 1
  fi
}

install_brew() {
  local installer

  if have_brew; then
    log_message "INFO: Homebrew is already installed."
    return
  fi

  prepare_brew_prefix

  installer="$(run_as_target_user mktemp "${TMPDIR:-/tmp}/homebrew-install.XXXXXX")"
  log_message "INFO: Downloading the Homebrew installer."

  if ! run_as_target_user curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh -o "$installer"; then
    log_message "ERROR: Failed to download the Homebrew installer."
    rm -f "$installer"
    exit 1
  fi

  log_message "INFO: Installing Homebrew as user $TARGET_USER in non-interactive mode."

  if ! run_as_target_user env HOME="$TARGET_HOME" NONINTERACTIVE=1 CI=1 /bin/bash "$installer"; then
    log_message "ERROR: Homebrew installer exited with a failure status."
    rm -f "$installer"
    exit 1
  fi
  rm -f "$installer"
  source_brew_environment

  if have_brew; then
    log_message "SUCCESS: Homebrew installation completed successfully."
  else
    log_message "ERROR: Homebrew installation failed."
    exit 1
  fi
}

detect_os
source_brew_environment || true

if have_required_packages && have_brew; then
  configure_sudo_homebrew_path
  log_message "INFO: Required commands and Homebrew are already present."
  exit 0
fi

find_missing_required_packages

if [ "${#MISSING_PACKAGES[@]}" -eq 0 ]; then
  log_message "INFO: All prerequisite packages are already installed; skipping distro package installation."
else

  case "$DISTRO_ID" in
    ubuntu)
      install_with_apt
      ;;
    fedora)
      if is_ostree && command -v rpm-ostree >/dev/null 2>&1; then
        install_with_rpm_ostree
      else
        install_with_dnf
      fi
      ;;
    arch|artix)
      install_with_pacman
      ;;
    void)
      install_with_xbps
      ;;
    alpine)
      install_with_apk
      ;;
    opensuse-microos|microos)
      install_with_transactional_update
      ;;
    opensuse*|sles)
      install_with_zypper
      ;;
    *)
      case " $DISTRO_LIKE " in
        *" debian "*)
          install_with_apt
          ;;
        *" arch "*)
          install_with_pacman
          ;;
        *" fedora "*|*" rhel "*)
          if is_ostree && command -v rpm-ostree >/dev/null 2>&1; then
            install_with_rpm_ostree
          else
            install_with_dnf
          fi
          ;;
        *" suse "*)
          if [ "$DISTRO_ID" = "opensuse-microos" ]; then
            install_with_transactional_update
          else
            install_with_zypper
          fi
          ;;
        *)
          log_message "ERROR: Unsupported distribution ID '$DISTRO_ID' (ID_LIKE='$DISTRO_LIKE')."
          exit 1
          ;;
      esac
      ;;
  esac
fi

configure_sudo_homebrew_path
install_brew

if have_required_packages && have_brew; then
  log_message "SUCCESS: git is available at $(command -v git)."
  log_message "SUCCESS: curl is available at $(command -v curl)."
  log_message "SUCCESS: zsh is available at $(command -v zsh)."
  log_message "SUCCESS: brew is available at $(command -v brew)."
else
  log_message "ERROR: Installation completed but one or more required commands are still unavailable in PATH."
  exit 1
fi
{{ end -}}
