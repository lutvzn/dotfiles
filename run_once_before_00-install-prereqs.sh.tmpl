{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

LOG_HOME="${ORIG_HOME:-$HOME}"
LOG_DIR="$LOG_HOME/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_once_before_00-install-prereqs.log"
REQUIRED_PACKAGES=(git curl)

mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

run_with_sudo() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return
  fi
  if ! command -v sudo >/dev/null 2>&1; then
    log_message "ERROR: sudo is required to install prerequisites."
    exit 1
  fi

  sudo "$@"
}

detect_os() {
  if [ ! -r /etc/os-release ]; then
    log_message "ERROR: /etc/os-release is not available. Cannot detect the operating system."
    exit 1
  fi

  . /etc/os-release
  DISTRO_ID="${ID:-}"
  DISTRO_LIKE="${ID_LIKE:-}"
}

install_with_apt() {
  log_message "INFO: Installing required packages with apt: ${REQUIRED_PACKAGES[*]}."

  if ! run_with_sudo apt-get update; then
    log_message "ERROR: apt-get update failed."
    exit 1
  fi

  if run_with_sudo apt-get install -y "${REQUIRED_PACKAGES[@]}"; then
    log_message "SUCCESS: Required packages installed with apt."
  else
    log_message "ERROR: Failed to install required packages with apt."
    exit 1
  fi
}

install_with_dnf() {
  log_message "INFO: Installing required packages with dnf: ${REQUIRED_PACKAGES[*]}."

  if run_with_sudo dnf install -y "${REQUIRED_PACKAGES[@]}"; then
    log_message "SUCCESS: Required packages installed with dnf."
  else
    log_message "ERROR: Failed to install required packages with dnf."
    exit 1
  fi
}

install_with_zypper() {
  log_message "INFO: Installing required packages with zypper: ${REQUIRED_PACKAGES[*]}."

  if run_with_sudo zypper --non-interactive refresh && run_with_sudo zypper --non-interactive install --no-confirm "${REQUIRED_PACKAGES[@]}"; then
    log_message "SUCCESS: Required packages installed with zypper."
  else
    log_message "ERROR: Failed to install required packages with zypper."
    exit 1
  fi
}

install_with_pacman() {
  log_message "INFO: Installing required packages with pacman: ${REQUIRED_PACKAGES[*]}."

  if run_with_sudo pacman -Sy --noconfirm "${REQUIRED_PACKAGES[@]}"; then
    log_message "SUCCESS: Required packages installed with pacman."
  else
    log_message "ERROR: Failed to install required packages with pacman."
    exit 1
  fi
}

install_with_xbps() {
  log_message "INFO: Installing required packages with xbps-install: ${REQUIRED_PACKAGES[*]}."

  if run_with_sudo xbps-install -Sy "${REQUIRED_PACKAGES[@]}"; then
    log_message "SUCCESS: Required packages installed with xbps-install."
  else
    log_message "ERROR: Failed to install required packages with xbps-install."
    exit 1
  fi
}

install_with_apk() {
  log_message "INFO: Installing required packages with apk: ${REQUIRED_PACKAGES[*]}."

  if run_with_sudo apk add "${REQUIRED_PACKAGES[@]}"; then
    log_message "SUCCESS: Required packages installed with apk."
  else
    log_message "ERROR: Failed to install required packages with apk."
    exit 1
  fi
}

have_required_packages() {
  local missing=0
  local package

  for package in "${REQUIRED_PACKAGES[@]}"; do
    if ! command -v "$package" >/dev/null 2>&1; then
      log_message "INFO: Missing required command: $package."
      missing=1
    fi
  done

  return "$missing"
}

source_brew_environment() {
  local brew_bin

  for brew_bin in \
    "/home/linuxbrew/.linuxbrew/bin/brew" \
    "/opt/homebrew/bin/brew" \
    "/usr/local/bin/brew"; do
    if [ -x "$brew_bin" ]; then
      eval "$("$brew_bin" shellenv)"
      return 0
    fi
  done

  return 1
}

have_brew() {
  command -v brew >/dev/null 2>&1
}

install_brew() {
  if have_brew; then
    log_message "INFO: Homebrew is already installed."
    return
  fi

  log_message "INFO: Installing Homebrew."

  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  source_brew_environment

  if have_brew; then
    log_message "SUCCESS: Homebrew installation completed successfully."
  else
    log_message "ERROR: Homebrew installation failed."
    exit 1
  fi
}

detect_os
source_brew_environment || true

if have_required_packages && have_brew; then
  log_message "INFO: Required commands and Homebrew are already present."
  exit 0
fi

case "$DISTRO_ID" in
  ubuntu)
    install_with_apt
    ;;
  fedora)
    install_with_dnf
    ;;
  arch|artix)
    install_with_pacman
    ;;
  void)
    install_with_xbps
    ;;
  alpine)
    install_with_apk
    ;;
  opensuse*|sles)
    install_with_zypper
    ;;
  *)
    case " $DISTRO_LIKE " in
      *" debian "*)
        install_with_apt
        ;;
      *" arch "*)
        install_with_pacman
        ;;
      *" fedora "*|*" rhel "*)
        install_with_dnf
        ;;
      *" suse "*)
        install_with_zypper
        ;;
      *)
        log_message "ERROR: Unsupported distribution ID '$DISTRO_ID' (ID_LIKE='$DISTRO_LIKE')."
        exit 1
        ;;
    esac
    ;;
esac

install_brew

if have_required_packages && have_brew; then
  log_message "SUCCESS: git is available at $(command -v git)."
  log_message "SUCCESS: curl is available at $(command -v curl)."
  log_message "SUCCESS: brew is available at $(command -v brew)."
else
  log_message "ERROR: Installation completed but one or more required commands are still unavailable in PATH."
  exit 1
fi
{{ end -}}
