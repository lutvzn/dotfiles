# .bashrc - Organized & Minimalist

# -----------------------------------------------------------------------------
# 1. Global Definitions & Non-Interactive Check
# -----------------------------------------------------------------------------

# Source global definitions
[ -f /etc/bashrc ] && . /etc/bashrc

# If not running interactively, don't do anything else
[[ $- != *i* ]] && return

# -----------------------------------------------------------------------------
# 2. Environment & PATH
# -----------------------------------------------------------------------------

# Prepend user bin and Nix directories
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

if [ -d "$HOME/.nix-profile/bin" ]; then
  export PATH="$HOME/.nix-profile/bin:$PATH"
fi

# Cargo / Rust environment
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# -----------------------------------------------------------------------------
# 3. Tool Initialization
# -----------------------------------------------------------------------------

# Specialized bash-prexec (often needed for Atuin)
[ -f /usr/share/bash-prexec ] && . /usr/share/bash-prexec

# Generic tool init (only if the command exists)
[ "$(command -v zoxide)" ] && eval "$(zoxide init bash)"
[ "$(command -v starship)" ] && eval "$(starship init bash)"
[ "$(command -v atuin)" ] && eval "$(atuin init bash)"
[ "$(command -v fzf)" ] && eval "$(fzf --bash)"

# -----------------------------------------------------------------------------
# 4. Aliases & Functions
# -----------------------------------------------------------------------------

# Modern replacements (eza for ls, ug for grep)
if command -v eza &>/dev/null; then
  alias ls='eza'
  alias ll='eza -l --icons=auto --group-directories-first'
  alias l.='eza -d .*'
  alias l1='eza -1'
fi

if command -v ug &>/dev/null; then
  alias grep='ug'
  alias egrep='ug -E'
  alias fgrep='ug -F'
fi

# Source custom scripts and external alias files
[ -f ~/.config/aliases ] && . ~/.config/aliases

if [ -d ~/.bashrc.d ]; then
  for rc in ~/.bashrc.d/*; do
    [ -f "$rc" ] && . "$rc"
  done
  unset rc
fi

# -----------------------------------------------------------------------------
# 5. Prompt Customization (Fallback)
# -----------------------------------------------------------------------------

# Note: If starship is active (initialized above), it will override this PS1.
# This serves as a clean backup prompt.
PS1='\[\e[1;32m\]\u@\h\[\e[m\] \[\e[1;36m\]\w\[\e[m\]\n\[\e[1;32m\]❯\[\e[m\] '
