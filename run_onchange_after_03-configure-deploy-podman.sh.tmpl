{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

LOG_DIR="${HOME:-/root}/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_onchange_after_03-configure-deploy-podman.log"
DEPLOY_USER="deploy"
DEPLOY_UID="5001"
SUBID_RANGE_START="165536"
SUBID_RANGE_COUNT="65536"

mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

ensure_root() {
  if [ "$(id -u)" -eq 0 ]; then
    return
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    log_message "ERROR: sudo is required to configure rootless Podman prerequisites."
    exit 1
  fi

  log_message "INFO: Escalating with sudo to configure Podman prerequisites."
  exec sudo bash "$0" "$@"
}

upsert_subid_entry() {
  local file_path="$1"
  local desired_entry="$DEPLOY_USER:$SUBID_RANGE_START:$SUBID_RANGE_COUNT"

  if [ ! -f "$file_path" ]; then
    touch "$file_path"
  fi

  if grep -q "^$DEPLOY_USER:" "$file_path"; then
    if sed -i "s|^$DEPLOY_USER:.*|$desired_entry|" "$file_path"; then
      log_message "INFO: Updated $file_path entry for $DEPLOY_USER."
    else
      log_message "ERROR: Failed to update $file_path."
      exit 1
    fi
  elif printf '%s\n' "$desired_entry" >>"$file_path"; then
    log_message "SUCCESS: Added $desired_entry to $file_path."
  else
    log_message "ERROR: Failed to write $file_path."
    exit 1
  fi
}

ensure_root "$@"

if ! getent passwd "$DEPLOY_USER" >/dev/null 2>&1; then
  log_message "ERROR: User $DEPLOY_USER does not exist. Run run_onchange_00-create-users first."
  exit 1
fi

if [ "$(id -u "$DEPLOY_USER")" != "$DEPLOY_UID" ]; then
  log_message "ERROR: User $DEPLOY_USER must have UID $DEPLOY_UID before Podman setup."
  exit 1
fi

upsert_subid_entry "/etc/subuid"
upsert_subid_entry "/etc/subgid"

if command -v loginctl >/dev/null 2>&1; then
  if loginctl enable-linger "$DEPLOY_USER"; then
    log_message "SUCCESS: Enabled lingering for $DEPLOY_USER."
  else
    log_message "WARNING: Failed to enable lingering for $DEPLOY_USER."
  fi
else
  log_message "WARNING: loginctl is not available; skipping lingering setup."
fi

deploy_home="$(getent passwd "$DEPLOY_USER" | cut -d: -f6)"
for path in \
  "$deploy_home/.config/containers" \
  "$deploy_home/.local/share/containers" \
  "$deploy_home/.config/systemd/user"; do
  if mkdir -p "$path"; then
    chown -R "$DEPLOY_USER:$DEPLOY_USER" "$path"
  else
    log_message "ERROR: Failed to create $path."
    exit 1
  fi
done

log_message "SUCCESS: Rootless Podman prerequisites configured for $DEPLOY_USER."
{{ end -}}
