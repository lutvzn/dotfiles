{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

# setup-users.yml hash: {{ include "dot_config/personalScripts/setup-users.yml" | sha256sum }}

LOG_HOME="${ORIG_HOME:-$HOME}"
LOG_DIR="$LOG_HOME/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_onchange_01-setup-users.log"
CHEZMOI_SOURCE_DIR="{{ .chezmoi.sourceDir }}"

mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

if ! command -v ansible-playbook >/dev/null 2>&1; then
  log_message "ERROR: ansible-playbook is not installed. Run run_onchange_02-install-packages first."
  exit 1
fi

PLAYBOOK_PATH="$CHEZMOI_SOURCE_DIR/dot_config/personalScripts/setup-users.yml"

if [ ! -f "$PLAYBOOK_PATH" ]; then
  log_message "ERROR: Ansible playbook not found at $PLAYBOOK_PATH."
  exit 1
fi

log_message "INFO: Applying user creation playbook $PLAYBOOK_PATH."
if [ "$(id -u)" -ne 0 ] && ! command -v sudo >/dev/null 2>&1; then
  log_message "ERROR: sudo is required to run the user creation playbook."
  exit 1
fi

ANSIBLE_PLAYBOOK_CMD=(ansible-playbook "$PLAYBOOK_PATH")

if [ "$(id -u)" -ne 0 ]; then
  log_message "INFO: Escalating with sudo to run the user creation playbook."
  ANSIBLE_PLAYBOOK_CMD=(sudo "${ANSIBLE_PLAYBOOK_CMD[@]}")
fi

if "${ANSIBLE_PLAYBOOK_CMD[@]}"; then
  log_message "SUCCESS: User bootstrap playbook applied successfully."
else
  log_message "ERROR: Failed to apply user bootstrap playbook."
  exit 1
fi
{{ end -}}
