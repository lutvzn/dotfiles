{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

# create-users.yml hash: {{ include "dot_config/personalScripts/create-users.yml" | sha256sum }}

LOG_HOME="${ORIG_HOME:-$HOME}"
LOG_DIR="$LOG_HOME/.config/personalScripts/logs"
LOG_FILE="$LOG_DIR/run_onchange_00-create-users.log"
DEFAULT_CHEZMOI_SOURCE_DIR="$LOG_HOME/.local/share/chezmoi"

mkdir -p "$LOG_DIR"

log_message() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

ensure_root() {
  if [ "$(id -u)" -eq 0 ]; then
    return
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    log_message "ERROR: sudo is required to create users."
    exit 1
  fi

  log_message "INFO: Escalating with sudo to create users."
  exec sudo ORIG_HOME="$HOME" bash "$0" "$@"
}

resolve_chezmoi_source_dir() {
  if command -v chezmoi >/dev/null 2>&1; then
    chezmoi source-path
  else
    echo "$DEFAULT_CHEZMOI_SOURCE_DIR"
  fi
}

ensure_root "$@"

if ! command -v ansible-playbook >/dev/null 2>&1; then
  log_message "ERROR: ansible-playbook is not installed. Run run_once_before_00-install-ansible first."
  exit 1
fi

CHEZMOI_SOURCE_DIR="$(resolve_chezmoi_source_dir)"
PLAYBOOK_PATH="$CHEZMOI_SOURCE_DIR/dot_config/personalScripts/create-users.yml"

if [ ! -f "$PLAYBOOK_PATH" ]; then
  log_message "ERROR: Ansible playbook not found at $PLAYBOOK_PATH."
  exit 1
fi

log_message "INFO: Applying user creation playbook $PLAYBOOK_PATH."
if ansible-playbook "$PLAYBOOK_PATH"; then
  log_message "SUCCESS: User bootstrap playbook applied successfully."
else
  log_message "ERROR: Failed to apply user bootstrap playbook."
  exit 1
fi
{{ end -}}
