# .zshrc - Organized & Minimalist (Adapted from .bashrc)

# -----------------------------------------------------------------------------
# 1. Global Definitions & Non-Interactive Check
# -----------------------------------------------------------------------------

# If not running interactively, don't do anything else
[[ -o interactive ]] || return

# -----------------------------------------------------------------------------
# 2. Environment & PATH
# -----------------------------------------------------------------------------

# Prepend user bin and Nix directories
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

if [ -d "$HOME/.nix-profile/bin" ]; then
  export PATH="$HOME/.nix-profile/bin:$PATH"
fi

# Cargo / Rust environment
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# -----------------------------------------------------------------------------
# 3. Prompt Customization (Fallback)
# -----------------------------------------------------------------------------

# This serves as a clean backup prompt.
# If tools like starship are initialized below, they will override this.
PROMPT='%F{green}%n@%m%f %F{cyan}%~%f
%F{green}❯%f '

# -----------------------------------------------------------------------------
# 4. Tool Initialization
# -----------------------------------------------------------------------------

# Generic tool init (only if the command exists)
[ "$(command -v zoxide)" ] && eval "$(zoxide init zsh)"
[ "$(command -v starship)" ] && eval "$(starship init zsh)"
[ "$(command -v atuin)" ] && eval "$(atuin init zsh)"
[ "$(command -v fzf)" ] && source <(fzf --zsh)
[ "$(command -v fnm)" ] && eval "$(fnm env --use-on-cd --shell zsh)"

# -----------------------------------------------------------------------------
# 5. Aliases & Functions
# -----------------------------------------------------------------------------

# Modern replacements (eza for ls, ug for grep)
if command -v eza &>/dev/null; then
  alias ls='eza'
  alias ll='eza -l --icons=auto --group-directories-first'
  alias l.='eza -d .*'
  alias l1='eza -1'
fi

if command -v ug &>/dev/null; then
  alias grep='ug'
  alias egrep='ug -E'
  alias fgrep='ug -F'
fi

# Source custom scripts and external alias files
[ -f ~/.config/aliases ] && . ~/.config/aliases

if [ -d ~/.zshrc.d ]; then
  for rc in ~/.zshrc.d/*; do
    [ -f "$rc" ] && . "$rc"
  done
  unset rc
fi
